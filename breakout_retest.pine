//@version=5
indicator("Breakout Retest Semanal (Justin Banks) — validado", overlay=true, max_labels_count=500, max_lines_count=500)

// =============================================================================
// ESTRATEGIA BREAKOUT RETEST (idea Justin Banks @RealUGBanks). PF 2.04 validado.
// ⚠️ USAR EN GRÁFICO SEMANAL (1S / 1W). Coincide con las señales del bot Telegram.
//
//   1. Cruce 8 EMA por encima de 21 EMA
//   2. Ruptura DECISIVA pero no fugitiva: cierre +3% a +15% sobre el máx de 8 sem
//   3. Entrada en el RETEST del nivel de ruptura (una sola vez)
//   4. Target +2R / salida si 8 cruza bajo 21 / stop 8% bajo la ruptura
// =============================================================================

resLB     = input.int(8,    "Lookback resistencia (semanas)")
breakMin  = input.float(3.0,  "Ruptura decisiva mín (%)") / 100.0
breakMax  = input.float(15.0, "Ruptura máx — anti-gap (%)") / 100.0
retestW   = input.int(6,    "Ventana de retest (semanas)")
retestBnd = input.float(2.0,  "Banda de retest (%)") / 100.0
stopBuf   = input.float(8.0,  "Stop bajo ruptura (%)") / 100.0
tpR       = input.float(2.0,  "Target (R)")

ef = ta.ema(close, 8)
es = ta.ema(close, 21)
plot(ef, "EMA 8",  color.new(color.orange, 0), 2)
plot(es, "EMA 21", color.new(color.blue,   0), 2)

// --- Paso 1+2: cruce + ruptura decisiva NO fugitiva ---
cross    = ta.crossover(ef, es)
resist   = ta.highest(high[1], resLB)
dist     = close / resist
breakBar = cross and dist > (1 + breakMin) and dist < (1 + breakMax)

var float breakoutLvl = na
var int   breakoutBar = na
var bool  entered     = false
if breakBar
    breakoutLvl := resist
    breakoutBar := bar_index
    entered     := false        // nueva ruptura → resetea la entrada

entry  = breakoutLvl
stopL  = breakoutLvl * (1 - stopBuf)
target = entry + tpR * (entry - stopL)

// --- RUPTURA: pon aquí la alerta de precio en el nivel límite ---
plotshape(breakBar, "RUPTURA", shape.labelup, location.belowbar, color.new(color.orange, 0), text="🟠 RUPTURA\nlímite ↓", textcolor=color.white, size=size.normal)
if breakBar
    line.new(bar_index, entry,  bar_index + 12, entry,  color=color.new(color.blue, 0),  style=line.style_solid,  width=2)
    line.new(bar_index, stopL,  bar_index + 12, stopL,  color=color.new(color.red, 0),   style=line.style_dashed, width=2)
    line.new(bar_index, target, bar_index + 12, target, color=color.new(color.green, 0), style=line.style_dashed, width=2)
    label.new(bar_index, entry,  "ZONA ENTRADA " + str.tostring(entry, "#.##") + "–" + str.tostring(entry*(1+retestBnd), "#.##"), style=label.style_label_left, color=color.new(color.blue, 80),  textcolor=color.blue,  size=size.small)
    label.new(bar_index, target, "TP +2R " + str.tostring(target, "#.##"),        style=label.style_label_left, color=color.new(color.green, 80), textcolor=color.green, size=size.small)
    label.new(bar_index, stopL,  "STOP -" + str.tostring(stopBuf*100,"#") + "% " + str.tostring(stopL, "#.##"), style=label.style_label_left, color=color.new(color.red, 80), textcolor=color.red, size=size.small)

// --- RETEST: marca UNA SOLA VEZ el primer retroceso al nivel (= tu entrada) ---
inWindow  = not na(breakoutBar) and (bar_index - breakoutBar) <= retestW and (bar_index - breakoutBar) > 0
retestNow = inWindow and not entered and not na(breakoutLvl) and low <= breakoutLvl * (1 + retestBnd) and ef > es
if retestNow
    entered := true
plotshape(retestNow, "RETEST — ENTRA", shape.labelup, location.belowbar, color.new(color.green, 0), text="✅ ENTRA", textcolor=color.white, size=size.small)

alertcondition(breakBar,  "Ruptura (pon alerta en el límite)", "RUPTURA semanal — pon alerta de compra en el nivel de ruptura")
alertcondition(retestNow, "RETEST — ENTRA AHORA", "El precio retestó el nivel — ENTRA (compra)")
